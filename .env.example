# ============================================
# SADOVA — переменные окружения (Beget hosting)
# ============================================
# Скопируйте в .env и заполните реальными значениями.
# НИКОГДА не коммитьте .env в git.

# --- База данных MySQL (Beget: Панель → MySQL) ---
# Формат: mysql://USER:PASSWORD@HOST:3306/DBNAME
DATABASE_URL="mysql://login_sadova:PASSWORD@localhost:3306/login_sadova"

# --- Сервер ---
NODE_ENV=production
PORT=3000
SITE_URL=https://sadova.ru

# --- Секреты сессий/JWT (сгенерируйте: openssl rand -hex 32) ---
SESSION_SECRET=change-me-to-random-64-hex
JWT_SECRET=change-me-to-random-64-hex

# --- OTP / Email (SMTP от Beget: smtp.beget.com) ---
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@sadova.ru
SMTP_PASSWORD=your-mailbox-password
SMTP_FROM="SADOVA <noreply@sadova.ru>"

# --- SMS (опционально, SMS.ru) ---
SMSRU_API_ID=
SMSRU_SENDER=SADOVA

# --- Платежи РФ (Т-Касса / T-Pay) — приём карт МИР/Visa/MC ---
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=
TINKOFF_NOTIFICATION_URL=https://sadova.ru/api/public/tinkoff/webhook

# --- СБП (Система Быстрых Платежей, НСПК через Т-Кассу) ---
SBP_MERCHANT_ID=
SBP_TERMINAL_KEY=

# --- SberPay / Сбербанк Эквайринг ---
SBERPAY_CLIENT_ID=
SBERPAY_CLIENT_SECRET=
SBERPAY_MERCHANT_LOGIN=
SBERPAY_MERCHANT_PASSWORD=

# --- T-Pay (Tinkoff Pay, кнопка «Оплатить в Т-Банке») ---
TPAY_MERCHANT_ID=
TPAY_SECRET=

# --- Доставка: Ozon Rocket (единственный способ) ---
OZON_ROCKET_CLIENT_ID=
OZON_ROCKET_CLIENT_SECRET=
OZON_ROCKET_WAREHOUSE_ID=

# --- Яндекс.Карты (браузерный ключ для карты ПВЗ) ---
# Получить: https://developer.tech.yandex.ru/services (JavaScript API и HTTP Геокодер)
VITE_YANDEX_MAPS_KEY=

# --- Соц-логин ---
VK_CLIENT_ID=
VK_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# --- Реквизиты ИП (для оферты/чеков) ---
MERCHANT_NAME="ИП Тогашев Альберт Даулетович"
MERCHANT_INN=
MERCHANT_OGRNIP=