# ============================================
# SADOVA — .env для внешнего хостинга (Beget)
# ============================================
# Заполните реальными значениями перед деплоем.
# НЕ коммитьте этот файл в git (уже в .gitignore).

# --- База данных MySQL 8 (Beget) ---
# localhost — если сайт и БД на одном сервере Beget (обычный shared/VPS Beget).
DATABASE_URL="mysql://albert83_2012:Kipi2020_@localhost:3306/albert83_2012"
# Внешнее подключение (с локального ПК, DBeaver и т.п.):
# DATABASE_URL="mysql://albert83_2012:Kipi2020_@albert83.beget.tech:3306/albert83_2012"

# --- Сервер ---
NODE_ENV=production
PORT=3000
SITE_URL=https://sadova.ru

# --- Секреты (openssl rand -hex 32) ---
SESSION_SECRET=REPLACE_WITH_64_HEX
JWT_SECRET=REPLACE_WITH_64_HEX

# --- OTP e-mail (SMTP Beget) ---
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@sadova.ru
SMTP_PASSWORD=REPLACE_MAILBOX_PASSWORD
SMTP_FROM="SADOVA <noreply@sadova.ru>"

# --- SMS (опционально) ---
SMSRU_API_ID=
SMSRU_SENDER=SADOVA

# --- Платежи Т-Касса (СБП / SberPay / T-Pay) ---
# https://www.tinkoff.ru/kassa/ → Личный кабинет → Терминалы
TKASSA_TERMINAL_KEY=
TKASSA_PASSWORD=
TKASSA_NOTIFICATION_URL=https://sadova.ru/api/public/payments/tkassa/webhook

# --- Резерв: ЮKassa (не используется по умолчанию) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# --- Доставка: Озон ПВЗ ---
# https://docs.ozon.ru/api/rest-postamat/
OZON_CLIENT_ID=
OZON_API_KEY=

# --- Доставка: Почта России ---
# https://tracking.pochta.ru/support/dictionaries/postal_service
POCHTA_TOKEN=
POCHTA_LOGIN=
POCHTA_PASSWORD=

# --- СДЭК (опционально) ---
CDEK_ACCOUNT=
CDEK_SECURE_PASSWORD=

# --- Соц-логин ---
VK_CLIENT_ID=
VK_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# --- Яндекс.Карты (карта ПВЗ) ---
VITE_YANDEX_MAPS_API_KEY=

# --- AI-чат (Lovable AI Gateway, Gemini) ---
LOVABLE_API_KEY=

